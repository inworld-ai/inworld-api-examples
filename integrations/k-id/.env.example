# k-ID API key from Compliance Studio (https://portal.k-id.com)
K_ID_API_KEY=your_kid_api_key_here

# k-ID API URL (use test environment for development)
K_ID_API_URL=https://game-api.test.k-id.com

# Inworld API key (Basic base64 key from https://platform.inworld.ai)
INWORLD_API_KEY=your_inworld_api_key_here

# Server port
PORT=3000

# Inworld session config
SYSTEM_PROMPT=You are a friendly voice assistant. Keep responses brief and conversational.
INWORLD_MODEL=openai/gpt-4o-mini
TTS_VOICE=Clive
