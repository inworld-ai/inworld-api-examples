# Inworld API key (Basic auth for LLM Router + TTS)
INWORLD_API_KEY=

# Public URL for this server (ngrok or deployed URL)
SERVER_URL=https://example.ngrok-free.app

# Server port (default: 3000)
PORT=3000

# System prompt for the voice assistant
SYSTEM_PROMPT="You are a helpful voice assistant powered by Inworld. Keep responses brief and conversational."

# Inworld LLM model or router name (default: openai/gpt-4.1-mini)
INWORLD_MODEL=openai/gpt-4.1-mini

# Inworld TTS voice name (default: Clive)
TTS_VOICE=Clive

# Inworld TTS model (default: inworld-tts-1.5-max)
TTS_MODEL=inworld-tts-1.5-max

# ConversationRelay transcription provider (default: Deepgram)
TRANSCRIPTION_PROVIDER=Deepgram

# Welcome greeting spoken when the call connects
WELCOME_GREETING="Hi! I'm an AI assistant powered by Inworld. How can I help you?"
