# The repo-root .gitignore is Python-oriented and ignores `lib/`; re-include the
# Flutter source directory, then re-exclude the gitignored secrets file.
!lib/
!lib/**
lib/secrets.dart

# Secrets — never commit a real key.

.DS_Store
